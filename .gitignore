# Python
__pycache__/
*.py[cod]
*$py.class

# PyInstaller build artifacts
build/
dist/
*.spec
# but track the build recipes themselves so the exes are reproducible
!PyGet.spec
!pyget-backend.spec

# Runtime data, logs, state (machine-specific)
downloads/
_extracted/
.pyget_state.json
*.pyget_state.json
.pyget_state.json*.bak
pyget.log
pyget.log.*
_debug_fuckingfast.html

# Node / Vite / Electron front-end (ui/)
ui/node_modules/
ui/dist/
ui/.output/
ui/.wrangler/
ui/electron-release/
ui/tsconfig.tsbuildinfo

# OS cruft
Thumbs.db
desktop.ini
.DS_Store

# Packaging outputs (large; rebuilt via pyget-backend.spec + electron-packager)
dist_backend/
ui/backend/
ui/electron-release/
ui/release/
